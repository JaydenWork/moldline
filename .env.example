# ── 서버 ──────────────────────────────────────────────
PORT=3000

# 의뢰 1건의 첨부 파일 총합 한도(MB). nginx client_max_body_size(deploy/nginx.conf)와 함께 조정할 것.
MAX_TOTAL_SIZE_MB=60

# 프론트엔드를 별도 호스팅(Netlify 등)할 때 호출을 허용할 출처. 쉼표로 여러 개 가능.
# 예: CORS_ORIGINS=https://moldline.netlify.app,https://moldline.kr
# 비워두면 동일 출처에서만 동작(프론트+백엔드를 한 서버에서 서빙하는 경우).
CORS_ORIGINS=

# ── 이메일 알림 (SMTP) ────────────────────────────────
# Gmail 예시: 2단계 인증 후 "앱 비밀번호"를 발급해 SMTP_PASS에 입력
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-account@gmail.com
SMTP_PASS=your-app-password

# 보내는 사람 / 받는 사람
MAIL_FROM="MOLDLINE <your-account@gmail.com>"
MAIL_TO=admin@moldline.kr
CONTACT_EMAIL=contact@moldline.kr

# 이메일 첨부 총 한도(MB). 이보다 큰 파일은 첨부하지 않고 서버 경로만 안내.
EMAIL_ATTACH_LIMIT_MB=20

# ── 디스코드 알림 (웹훅) ──────────────────────────────
# 채널 설정 → 연동 → 웹훅 → 새 웹훅 → "웹후크 URL 복사" 한 값을 붙여넣기
DISCORD_WEBHOOK_URL=
# 첨부 총 한도(MB). 디스코드 무료 서버 업로드 한도는 8MB. 초과 파일은 목록으로만 안내.
DISCORD_ATTACH_LIMIT_MB=8
# (선택) 알림 시 멘션. 예: @here  또는  <@&역할ID>  (비우면 멘션 없음)
DISCORD_MENTION=

# ── 텔레그램 알림 (봇) ────────────────────────────────
# Render 등 데이터센터에서 Discord가 429로 막힐 때 권장(Cloudflare 봇 차단 없음).
# 1) 텔레그램에서 @BotFather → /newbot → 토큰 발급 → TELEGRAM_BOT_TOKEN
# 2) 봇과 대화 시작(또는 그룹에 봇 초대) 후 아무 메시지 전송
# 3) https://api.telegram.org/bot<토큰>/getUpdates 열어 chat.id 확인 → TELEGRAM_CHAT_ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# 첨부 총 한도(MB). 텔레그램 봇 업로드 한도는 50MB. 초과 파일은 목록으로만 안내.
TELEGRAM_ATTACH_LIMIT_MB=50

# ── 텔레그램 유지보수 봇 (npm run bot — 항상 켜진 PC에서 실행) ──────────
# 텔레그램으로 지시를 보내면 이 PC의 Claude Code가 사이트를 수정·커밋하고
# 승인 시 push → Render 자동 배포. 위 TELEGRAM_BOT_TOKEN/CHAT_ID 재사용.
# (선택) 명령 허용 chat ID 목록(쉼표 구분). 미지정 시 TELEGRAM_CHAT_ID 사용.
TELEGRAM_MAINTAINER_CHAT_IDS=
# true면 수정·커밋 직후 자동 push(배포). 기본 false = 텔레그램에서 /push 승인 필요.
AUTO_PUSH=false
# Claude 1회 작업 타임아웃(초). 기본 600. (유지보수 봇·브레인스토밍 봇 공통)
BOT_CLAUDE_TIMEOUT_SEC=600

# ── 텔레그램 브레인스토밍 룸 봇 (npm run brainstorm) ──────────
# 한 방에서 💡 아이디어봇 ↔ 🛠️ PM봇 이 핑퐁하며 개선안을 냄. 봇은 토론만,
# 코드는 /apply 로 사람이 승인할 때만 수정·커밋(배포는 그 뒤 /push).
# ⚠️ 유지보수 봇과 "다른" 전용 봇 토큰을 쓸 것. 같은 토큰을 동시에 polling 하면
#    getUpdates 가 충돌해 메시지가 서로 사라짐. @BotFather 로 새 봇을 하나 더 만드세요.
TELEGRAM_BRAINSTORM_BOT_TOKEN=
# 이 봇을 쓸 chat ID(쉼표 구분). 그룹에서 쓰려면 그 그룹의 ID(보통 음수 -100...).
# 미지정 시 TELEGRAM_MAINTAINER_CHAT_IDS → TELEGRAM_CHAT_ID 순으로 폴백.
TELEGRAM_BRAINSTORM_CHAT_IDS=

# ── 관리자 페이지 (/admin) ────────────────────────────
# 접수 내역 조회/다운로드 보호용 계정. 반드시 강력한 비밀번호로 설정하세요.
ADMIN_USER=admin
ADMIN_PASS=change-this-to-a-strong-password
